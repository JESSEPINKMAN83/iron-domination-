VITE_MULTIPLAYER_SERVER_URL=http://127.0.0.1:8787

# Set on the deployed relay host, not in the Netlify client.
# Example: ALLOWED_ORIGINS=https://your-game.netlify.app,http://localhost:5173
ALLOWED_ORIGINS=

# Relay reliability and abuse controls. Defaults shown below normally need no changes.
RECONNECT_GRACE_MS=60000
MAX_COMMANDS_PER_SECOND=180
EXPOSE_ROOMS=false
